{
  "manifest_version": 3,
  "name": "TabDeck",
  "version": "0.1.0",
  "description": "TabDeck is a Chrome new-tab extension for organizing open tabs into a calm dashboard.",
  "permissions": ["tabs", "storage"],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "TabDeck"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
