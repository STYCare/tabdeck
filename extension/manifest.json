{
  "manifest_version": 3,
  "name": "清页 TabDeck",
  "version": "0.1.0",
  "description": "一个把新标签页变成标签整理面板的 Chrome 扩展。English name: TabDeck.",
  "permissions": ["tabs", "storage"],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "清页 TabDeck"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
